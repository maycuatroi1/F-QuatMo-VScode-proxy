# Server Settings
PORT=3000

# Redis Connection
REDIS_URL=redis://localhost:6379

# Proxy access key
# Leave empty to auto-generate a runtime key in the form sk-... and print it at startup.
PROXY_API_KEY=

# JWT Secret Key for signing student exam tokens (Leave empty to auto-generate a secure random key at startup)
JWT_SECRET=

# Upstream LLM Provider API Keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Custom Upstream Model Configuration (Gemma)
CUSTOM_BASE_URL=https://quatmo-api.iahn.hanoi.vn/v1
CUSTOM_API_KEY=
CUSTOM_MODEL_NAME=gemma-4
# Optional extra aliases that should also resolve to the custom upstream.
# Example: CUSTOM_MODEL_ALIASES=gemma,qwen3-coder
CUSTOM_MODEL_ALIASES=

# Local OSS Endpoint
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Classifier Settings
CLASSIFIER_API_URL=http://127.0.0.1:8000/classify
# Optional API Key for securing the communication between the Proxy and the Classifier API
CLASSIFIER_API_KEY=
